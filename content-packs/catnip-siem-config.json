      {
        "_scope": "DEFAULT",
        "id": "69e003ae1511c22199e245a2",
        "title": "SSH Brute Force Detection",
        "description": "Triggers when failed SSH login attempts exceed 10 within 5 minutes \u2014 indicates a brute force attack in progress",
        "remediation_steps": "1. Block source IP at firewall immediately\n2. Review all affected usernames in the alert\n3. Check if any failed attempts were followed by a successful login from the same IP\n4. Reset passwords for any successfully compromised accounts\n5. Review /var/log/auth.log for full attack timeline\n6. Add source IP to threat intelligence blocklist\n7. Consider implementing fail2ban to automate IP blocking",
        "updated_at": "2026-04-15T21:31:25.983Z",
        "matched_at": "2026-04-15T22:36:26.059Z",
        "priority": 3,
