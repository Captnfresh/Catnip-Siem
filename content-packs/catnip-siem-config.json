      {
        "_scope": "DEFAULT",
        "id": "69e008361511c22199e25300",
        "title": "Credential Stuffing Attack",
        "description": "Triggers when credential stuffing attempts exceed 20 within 5 minutes from a single IP \u2014 indicates automated account takeover attempt",
        "remediation_steps": "1. Block source IP at firewall immediately\n2. Force password reset for all targeted player accounts\n3. Enable CAPTCHA on login endpoints\n4. Check for successful logins following the attack from same IP\n5. Review affected usernames for account compromise\n6. Add source IP to threat intelligence blocklist\n7. Consider implementing account lockout after 5 failed attempts",
        "updated_at": "2026-04-15T21:50:46.550Z",
        "matched_at": "2026-04-15T23:05:46.732Z",
        "priority": 3,
        "alert": true,
        "config": {
          "type": "aggregation-v1",
          "query": "event_type:player_auth AND action:credential_stuffing",
          "query_parameters": [],
          "filters": [],
          "streams": [],
          "stream_categories": [],
          "group_by": [
            "source_ip"
          ],
          "series": [
            {
