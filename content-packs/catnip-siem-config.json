      {
        "_scope": "DEFAULT",
        "id": "69e009fd1511c22199e25b82",
        "title": "Suspicious Dev SSH Login",
        "description": "Triggers when a suspicious SSH login is detected on any dev server \u2014 indicates potential insider threat or compromised developer credentials",
        "remediation_steps": "1. Immediately revoke SSH access for the affected user\n2. Check if source IP matches known developer locations\n3. Review all commands executed during the session\n4. Force password reset for the affected developer account\n5. Check for lateral movement to other dev servers from same IP\n6. Review git commit history for any malicious code changes\n7. Escalate to security team if compromise is confirmed",
        "updated_at": "2026-04-15T21:58:21.656Z",
        "matched_at": "2026-04-15T23:03:19.132Z",
