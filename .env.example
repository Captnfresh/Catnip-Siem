# =============================================================
# Catnip Games SIEM - Environment Configuration Template
# =============================================================
# Copy this file to .env and fill in the real values.
# Real values are shared privately with team via WhatsApp.
# DO NOT commit .env to Git — it contains secrets.
# =============================================================

# ─────────────────────────────────────────
# Graylog core
# ─────────────────────────────────────────
# Random 64+ character string used by Graylog to encrypt stored credentials.
# Generate with: pwgen -N 1 -s 96
GRAYLOG_PASSWORD_SECRET=

# SHA256 hash of the admin password.
# Generate with: echo -n "YourPassword" | sha256sum
GRAYLOG_ROOT_PASSWORD_SHA2=

# The PLAINTEXT admin password (needed by the bootstrap script for API calls).
# MUST be the same password you hashed into GRAYLOG_ROOT_PASSWORD_SHA2 above.
GRAYLOG_ADMIN_PASSWORD=

# External URI where Graylog UI will be accessible.
GRAYLOG_HTTP_EXTERNAL_URI=http://localhost:9000/

# ─────────────────────────────────────────
# OpenSearch
# ─────────────────────────────────────────
OPENSEARCH_ADMIN_PASSWORD=

# ─────────────────────────────────────────
# SMTP email (for alert notifications — Gmail)
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
